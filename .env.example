# Server Config
PORT=8000
HOST=127.0.0.1

# LLM Configuration
# Options: "ollama" or "openai"
LLM_PROVIDER=ollama
LLM_MODEL=llama3

# Local Ollama URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI Configuration (leave empty if using Ollama)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Azure DevOps Configuration
AZURE_ORGANIZATION=your_org_name
AZURE_PROJECT=your_project_name
AZURE_PAT=your_personal_access_token_here
AZURE_API_VERSION=7.1

# Work Item Type Mappings (e.g., set STORY to "User Story" for Agile, "Product Backlog Item" for Scrum)
AZURE_FEATURE_TYPE=Feature
AZURE_STORY_TYPE=User Story
AZURE_TASK_TYPE=Task
